<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Todo List APP test</title>

    <!-- Font Awesome -->
    <link rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: Arial, sans-serif;
            background: #f4f6f9;
            color: #333;
            padding: 20px;
        }

        h1 {
            background: linear-gradient(135deg, #4CAF50, #45a049);
            color: white;
            text-align: center;
            padding: 25px 15px;
            border-radius: 12px;
            margin-bottom: 30px;
            font-size: clamp(1.5rem, 4vw, 2.8rem);
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        }

        form {
            max-width: 800px;
            margin: 0 auto 30px;
            background: #fff;
            padding: 25px;
            border-radius: 12px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        }

        label {
            display: block;
            margin-bottom: 12px;
            font-size: 1.1rem;
            font-weight: bold;
        }

        input[type="text"] {
            width: 100%;
            padding: 14px;
            border: 1px solid #ddd;
            border-radius: 8px;
            font-size: 16px;
            margin-bottom: 15px;
            outline: none;
            transition: border 0.3s ease;
        }

        input[type="text"]:focus {
            border-color: #4CAF50;
        }

        input[type="submit"] {
            background-color: #4CAF50;
            color: white;
            border: none;
            padding: 12px 30px;
            border-radius: 8px;
            cursor: pointer;
            font-size: 16px;
            transition: all 0.3s ease;
        }

        input[type="submit"]:hover {
            background-color: #45a049;
            transform: translateY(-2px);
        }

        ul {
            max-width: 800px;
            margin: 0 auto;
            list-style: none;
        }

        ul li {
            background: #fff;
            border-radius: 10px;
            margin-bottom: 15px;
            padding: 18px 110px 18px 20px;
            position: relative;
            box-shadow: 0 2px 6px rgba(0,0,0,0.08);
            word-wrap: break-word;
            font-size: 1rem;
        }

        /* Action Buttons */

        .edit-btn,
        .delete-btn {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            width: 38px;
            height: 38px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            text-decoration: none;
            transition: all 0.3s ease;
        }

        .edit-btn {
            right: 60px;
            background: rgba(255, 193, 7, 0.15);
            color: #f4b400;
        }

        .delete-btn {
            right: 15px;
            background: rgba(244, 67, 54, 0.15);
            color: #f44336;
        }

        .edit-btn:hover {
            background: #f4b400;
            color: #fff;
            transform: translateY(-50%) scale(1.1);
        }

        .delete-btn:hover {
            background: #f44336;
            color: #fff;
            transform: translateY(-50%) scale(1.1);
        }

        /* Tablet */

        @media (max-width: 768px) {
            body {
                padding: 15px;
            }

            form {
                padding: 20px;
            }

            ul li {
                padding: 15px 100px 15px 15px;
            }
        }

        /* Mobile */

        @media (max-width: 480px) {

            h1 {
                padding: 18px 10px;
            }

            form {
                padding: 15px;
            }

            input[type="submit"] {
                width: 100%;
            }

            ul li {
                font-size: 14px;
                padding-right: 90px;
            }

            .edit-btn {
                right: 50px;
                width: 34px;
                height: 34px;
            }

            .delete-btn {
                right: 10px;
                width: 34px;
                height: 34px;
            }
        }
    </style>
</head>

<body>

    <h1>Hello, Write your plan on Learning Jenkins CI/CD</h1>

    <ul>
        <% todolist.forEach(function(todo, index) { %>
            <li>

                <a href="/todo/<%= index %>" class="edit-btn">
                    <i class="fa-solid fa-pen-to-square"></i>
                </a>

                <a href="/todo/delete/<%= index %>" class="delete-btn">
                    <i class="fa-solid fa-trash"></i>
                </a>

                <%- todo %>

            </li>
        <% }); %>
    </ul>

    <form action="/todo/add/" method="post">
        <p>
            <label for="newtodo">What should I do?</label>
            <input type="text" name="newtodo" id="newtodo" autofocus />
            <input type="submit" value="Add" />
        </p>
    </form>

</body>
</html>